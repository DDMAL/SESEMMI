# ── Virtuoso ─────────────────────────────────
VIRTUOSO_ENDPOINT=https://virtuoso.simssa.ca/sparql

# ── Logging ──────────────────────────────────
LOG_LEVEL=info

# ── Nginx ─────────────────────────────────────
HOST_NAME=localhost

# ── LLM Service ───────────────────────────────
LLM_SERVICE_URL=http://llm:8000        # Docker internal URL (default, no change needed)

# ── LLM Provider ─────────────────────────────
# Switch providers by changing LLM_PROVIDER and LLM_MODEL — keys for all providers stay here
LLM_PROVIDER=ollama                    # ollama | openai | anthropic | gemini
LLM_MODEL=qwen3:1.7b                   # ollama: qwen3:1.7b, qwen3:4b | openai: gpt-4o-mini, gpt-4o | anthropic: claude-haiku-4-5-20251001, claude-sonnet-4-6 | gemini: gemini-2.5-flash-lite, gemini-2.0-flash

# API keys — fill all; only the active provider's key is used
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# GEMINI_API_KEY=your_gemini_key

# ── Ollama ────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_THREAD=2                    # match vCPU count
OLLAMA_THINK=false                     # IMPORTANT: keep false — Qwen3 thinking mode is slow on CPU

# ── Wikidata MCP ────────────────────────────────
WIKIDATA_MCP_URL=https://wd-mcp.wmcloud.org/mcp/

# ── RAG Service ─────────────────────────────
RAG_TOP_K=5
RAG_ENABLED=false
EMBEDDING_MODEL=nomic-embed-text       # pulled via same Ollama server (only used when RAG_ENABLED=true)

# ── FEW SHOT ──────────────────────────────────
FEW_SHOT_ENABLED=false

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sesemmi

# ── LangGraph Agent ───────────────────────────
GRAPH_ENABLED=false
SEMANTIC_JUDGE_ENABLED=false
MAX_REPAIR_ITERATIONS=3
SPARQL_TIMEOUT=120             # seconds; raise for slow federated queries

# ── LangSmith Tracing (optional) ──────────────
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your_langsmith_key
# LANGSMITH_PROJECT=sesemmi-agent

# ── Production only ───────────────────────────
# POSTGRES_PASSWORD=change_me