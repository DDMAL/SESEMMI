# ── Virtuoso ─────────────────────────────────
VIRTUOSO_ENDPOINT=https://virtuoso.simssa.ca/sparql

# ── Logging ──────────────────────────────────
LOG_LEVEL=info

# ── Nginx ─────────────────────────────────────
HOST_NAME=localhost

# ── LLM Service ───────────────────────────────
LLM_SERVICE_URL=http://llm:8000        # Docker internal URL (default, no change needed)
LLM_API_KEY=your_google_ai_key         # Get from https://ai.google.dev — used by llm-service
LLM_MODEL=gemini-2.5-flash-lite        # Used by llm-service

# ── RAG Service ─────────────────────────────
RAG_TOP_K=5
RAG_ENABLED=false

# ── FEW SHOT ──────────────────────────────────
FEW_SHOT_ENABLED=false

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sesemmi

# ── LangGraph Agent ───────────────────────────
GRAPH_ENABLED=false
SEMANTIC_JUDGE_ENABLED=false
MAX_REPAIR_ITERATIONS=3
SPARQL_TIMEOUT=120             # seconds; raise for slow federated queries

# ── LangSmith Tracing (optional) ──────────────
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your_langsmith_key
# LANGSMITH_PROJECT=sesemmi-agent

# ── Production only ───────────────────────────
# POSTGRES_PASSWORD=change_me